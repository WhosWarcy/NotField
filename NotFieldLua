				newVal = math.clamp(newVal, min, max)
				currentVal = newVal
				if flag then NotField.Flags[flag] = currentVal end
				
				local percentage = (newVal - min) / (max - min)
				fill.Size = UDim2.new(percentage, 0, 1, 0)
				knob.Position = UDim2.new(percentage, 0, 0.5, 0)
				valLabel.Text = tostring(math.floor(newVal)) .. " " .. suffix
				callback(newVal)
