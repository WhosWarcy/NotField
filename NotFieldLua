        titleLabel.Parent = titleBar

        -- Settings gear
        local settingsButton = Instance.new("TextButton")
        settingsButton.Size = UDim2.new(0, 30, 0, 30)
        settingsButton.Position = UDim2.new(1, -60, 0.5, -15)
        settingsButton.BackgroundTransparency = 1
