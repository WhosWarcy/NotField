		function Tab:CreateDropdown(dropdownOptions)
			dropdownOptions = dropdownOptions or {}
			local name = dropdownOptions.Name or "Dropdown"
			local options = dropdownOptions.Options or {}
			local currentOpt = dropdownOptions.CurrentOption or {}
			local callback = dropdownOptions.Callback or function() end
			
			local selectedVal = typeof(currentOpt) == "table" and currentOpt[1] or currentOpt or ""
			
			local dropdownFrame = Instance.new("Frame")
			dropdownFrame.Size = UDim2.new(1, -24, 0, 38)
			dropdownFrame.BackgroundColor3 = Theme.ElementBackground
			dropdownFrame.BorderSizePixel = 0
			dropdownFrame.ClipsDescendants = true
			dropdownFrame.Parent = tabPage
			
			Instance.new("UICorner", dropdownFrame).CornerRadius = UDim.new(0, 6)
			local elStroke = Instance.new("UIStroke", dropdownFrame)
			elStroke.Color = Theme.ElementStroke
			
			applyElementGradient(dropdownFrame)
			
			local title = Instance.new("TextLabel")
			title.Size = UDim2.new(0.5, 0, 0, 38)
			title.Position = UDim2.new(0, 12, 0, 0)
			title.BackgroundTransparency = 1
			title.Text = name
			title.TextColor3 = Theme.TextColor
			setFontMedium(title)
			title.TextSize = 13
			title.TextXAlignment = Enum.TextXAlignment.Left
			title.Parent = dropdownFrame
			
			local valLabel = Instance.new("TextLabel")
			valLabel.Size = UDim2.new(0, 100, 0, 38)
			valLabel.Position = UDim2.new(1, -140, 0, 0)
			valLabel.BackgroundTransparency = 1
			valLabel.Text = selectedVal
			valLabel.TextColor3 = Theme.AccentLight
			setFontMedium(valLabel)
			valLabel.TextSize = 12
			valLabel.TextXAlignment = Enum.TextXAlignment.Right
			valLabel.Parent = dropdownFrame
			
			local trigger = Instance.new("TextButton")
			trigger.Size = UDim2.new(1, 0, 0, 38)
			trigger.BackgroundTransparency = 1
			trigger.Text = ""
			trigger.Parent = dropdownFrame
			
			local arrow = Instance.new("TextLabel")
			arrow.Size = UDim2.new(0, 38, 0, 38)
			arrow.Position = UDim2.new(1, -38, 0, 0)
			arrow.BackgroundTransparency = 1
			arrow.Text = "▼"
			arrow.TextColor3 = Theme.TextColor
			arrow.Font = Enum.Font.SourceSansBold
			arrow.TextSize = 14
			arrow.Parent = dropdownFrame
			
			local optionsContainer = Instance.new("Frame")
			optionsContainer.Size = UDim2.new(1, -24, 0, 0)
			optionsContainer.Position = UDim2.new(0, 12, 0, 40)
			optionsContainer.BackgroundTransparency = 1
			optionsContainer.Parent = dropdownFrame
			
			local optionsLayout = Instance.new("UIListLayout")
			optionsLayout.Padding = UDim.new(0, 4)
			optionsLayout.Parent = optionsContainer
			
			local open = false
			
			local function buildOptions()
				for _, child in ipairs(optionsContainer:GetChildren()) do
					if child:IsA("TextButton") then child:Destroy() end
				end
				for _, option in ipairs(options) do
					local optBtn = Instance.new("TextButton")
					optBtn.Size = UDim2.new(1, 0, 0, 28)
					optBtn.BackgroundColor3 = Color3.fromRGB(41, 41, 41)
					optBtn.Text = "  " .. option
					optBtn.TextColor3 = Theme.TextColor
					setFontMedium(optBtn)
					optBtn.TextSize = 12
					optBtn.TextXAlignment = Enum.TextXAlignment.Left
					optBtn.AutoButtonColor = false
					optBtn.Parent = optionsContainer
					
					Instance.new("UICorner", optBtn).CornerRadius = UDim.new(0, 4)
					local optStroke = Instance.new("UIStroke", optBtn)
					optStroke.Color = Theme.ElementStroke
					
					optBtn.MouseButton1Click:Connect(function()
						selectedVal = option
						valLabel.Text = selectedVal
						open = false
						TweenService:Create(dropdownFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quart), { Size = UDim2.new(1, -24, 0, 38) }):Play()
						arrow.Text = "▼"
						callback({option})
					end)
				end
			end
			buildOptions()
			
			trigger.MouseButton1Click:Connect(function()
				open = not open
				if open then
					buildOptions()
					local targetHeight = 44 + (#options * 32)
					TweenService:Create(dropdownFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quart), { Size = UDim2.new(1, -24, 0, targetHeight) }):Play()
					arrow.Text = "▲"
				else
					TweenService:Create(dropdownFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quart), { Size = UDim2.new(1, -24, 0, 38) }):Play()
					arrow.Text = "▼"
				end
			end)
			
			local dropdownObj = {}
			function dropdownObj:Set(newOption)
				selectedVal = typeof(newOption) == "table" and newOption[1] or newOption
				valLabel.Text = selectedVal
				callback({selectedVal})
			end
			function dropdownObj:Refresh(newOptions, defaultOpt)
				options = newOptions
				buildOptions()
				if defaultOpt then
					selectedVal = typeof(defaultOpt) == "table" and defaultOpt[1] or defaultOpt
					valLabel.Text = selectedVal
				end
			end
			
			return dropdownObj
		end
		
