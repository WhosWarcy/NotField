            mainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
            TweenService:Create(mainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Size = UDim2.new(0, 600, 0, 400),
                Position = UDim2.new(0.5, -300, 0.5, -200)
            }):Play()
        end
        local function closeGUI()
            TweenService:Create(mainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                Size = UDim2.new(0, 0, 0, 0),
                Position = UDim2.new(0.5, 0, 0.5, 0)
            }):Play()
            task.delay(0.2, function()
                screenGui.Enabled = false
            end)
        end

        -- ---- Keybind ----
        local function updateToggleKeybind(newKeyName)
            if toggleKeyConn then toggleKeyConn:Disconnect() toggleKeyConn = nil end
            local key = Enum.KeyCode[newKeyName]
            if key then
                toggleKeyConn = UserInputService.InputBegan:Connect(function(input, processed)
                    if processed then return end
                    if input.KeyCode == key then
                        if screenGui.Enabled then closeGUI() else openGUI() end
                    end
                end)
                currentKeyName = newKeyName
            else
                NotField:Notify("Invalid key name: " .. newKeyName)
                updateToggleKeybind(currentKeyName)
            end
        end
        updateToggleKeybind(currentKeyName)

