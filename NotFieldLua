        tabContentScrolling.ScrollBarImageColor3 = Color3.fromRGB(100, 100, 100)
        tabContentScrolling.Parent = contentFrame

        local tabUILayout = Instance.new("UIListLayout")
        tabUILayout.Padding = UDim.new(0, 6)
        tabUILayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        tabUILayout.SortOrder = Enum.SortOrder.LayoutOrder
